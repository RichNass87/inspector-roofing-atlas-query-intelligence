{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inspector-roofing.com/ip/schema/legal_authority_reference.schema.json",
  "title": "Inspector Roofing Legal Authority Reference",
  "type": "object",
  "required": [
    "name",
    "type",
    "status",
    "verification_url"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "serial_number": {
      "type": "string"
    },
    "doi": {
      "type": "string"
    },
    "verification_url": {
      "type": "string",
      "format": "uri"
    },
    "scope_note": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
